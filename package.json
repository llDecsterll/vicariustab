{
  "name": "vicariustab",
  "private": true,
  "version": "2.0.5",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "vite build --mode production && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --minify --legal-comments=none --outfile=dist/server.cjs && node -e \"require('fs').mkdirSync('dist/server',{recursive:true}); require('fs').copyFileSync('server/workspaceSeed.json','dist/server/workspaceSeed.json')\"",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n.mjs",
    "verify": "node scripts/verify-flow.mjs",
  "verify:install": "node scripts/verify-install.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "javascript-obfuscator": "^5.4.3",
    "puppeteer-core": "^24.43.1",
    "rollup-plugin-obfuscator": "^1.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
