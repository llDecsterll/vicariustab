# Release
# Server port (default 3000). Use 8080 if keyserver also runs on 3000.
PORT=8080

# AES-256 encryption key for db.json and SQL credential blobs.
# Generate a long random string for production.
DB_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Persistent data directory (db.json, db_config.json) when running in Docker
STACK_DATA_DIR=/app/data

DB_HOST_GATEWAY=host.docker.internal

# Official GitHub repository for update checks and git pull
GITHUB_UPDATE_REPO=https://github.com/llDecsterll/uvwstack.git
