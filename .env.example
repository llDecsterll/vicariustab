# Release
# Server port (default 3000). Use 8080 if keyserver also runs on 3000.
PORT=8080

# AES-256 encryption key for db.json and SQL credential blobs.
# Generate a long random string for production.
DB_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Persistent data directory (db.json, db_config.json) when running in Docker
STACK_DATA_DIR=/app/data

DB_HOST_GATEWAY=host.docker.internal

# Auto-connect when using docker-compose.mysql.yml / docker-compose.postgres.yml / docker-compose.host.yml
# STACK_DEFAULT_DB_TYPE=mysql
# STACK_DEFAULT_DB_HOST=mysql
# STACK_DEFAULT_DB_PORT=3306
# STACK_DEFAULT_DB_NAME=stack_db
# STACK_DEFAULT_DB_USER=stack_user
# STACK_DEFAULT_DB_PASSWORD=StackUser2026!

# Host network (docker-compose.host.yml) — native MySQL/PostgreSQL on Ubuntu:
# STACK_DEFAULT_DB_TYPE=postgres
# STACK_DEFAULT_DB_HOST=127.0.0.1
# STACK_DEFAULT_DB_PORT=5432

# MYSQL_PASSWORD=StackUser2026!
# MYSQL_ROOT_PASSWORD=StackRoot2026!
# POSTGRES_PASSWORD=StackUser2026!

# Official GitHub repository for update checks and auto-update
GITHUB_UPDATE_REPO=https://github.com/llDecsterll/vicariustab.git
# Auto-update from GitHub (PM2 / native install; requires writable app directory)
# STACK_DISABLE_AUTO_UPDATE=true
# PM2_APP_NAME=vicariustab-system

# --- External domain & HTTPS (Docker Caddy or reverse proxy) ---
# DNS A-record must point to your server before enabling Caddy / Let's Encrypt.
# STACK_DOMAIN=stack.example.com
# STACK_PUBLIC_URL=https://stack.example.com
# STACK_TLS_EMAIL=admin@example.com
# TRUST_PROXY=true
# STACK_FORCE_HTTPS=false
